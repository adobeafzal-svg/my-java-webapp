<?xml version="1.0" encoding="UTF-8"?>
<!--
    WEB.XML - Deployment Descriptor
    
    NOTE: This file is OPTIONAL in Servlet 3.0+ because we use annotations.
    Included here for reference and for any non-annotated configuration.
    
    In your old J2EE days, this was REQUIRED and contained all servlet mappings.
    Now, @WebServlet annotation handles most of this automatically.
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee 
                             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">
    
    <display-name>My Web Application</display-name>
    <description>Sample application for CI/CD learning</description>
    
    <!-- 
        Welcome file - what to show when accessing root URL
        These are checked in order until one is found
    -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    <!--
        Session configuration
        30 minute timeout (in minutes)
    -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    
    <!--
        Error pages - friendly error handling
        In production, you'd have custom error pages
    -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.html</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.html</location>
    </error-page>
    
</web-app>
